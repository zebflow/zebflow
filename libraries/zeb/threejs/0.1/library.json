{
  "name": "zeb/threejs",
  "version": "0.1",
  "kind": "web-library",
  "trust": "official",
  "description": "Three.js r183 full bundle for TSX templates. All Three.js classes + scene runtime, canvas mounting, and RWE hooks.",
  "source": {
    "provider": "zebflow",
    "package": "three",
    "package_version": "0.183.2",
    "packed_version": "full-r183",
    "packed_kind": "full",
    "entry": "runtime/threejs.bundle.mjs"
  },
  "registry": {
    "kind": "github-releases",
    "repo": "zebflow/libraries",
    "asset_pattern": "zeb-threejs-{version}.bundle.mjs"
  },
  "exports": {
    "raw": [
      "threejs",
      "ensureThree",
      "createSceneRuntime",
      "mountThreeScene"
    ],
    "wrappers": [
      "ThreeScene"
    ]
  },
  "runtime": {
    "format": "esm",
    "entry": "runtime/threejs.bundle.mjs"
  },
  "editor": {
    "keywords": "keywords.json",
    "exports": "exports.json"
  }
}