{
  "name": "zeb/icons",
  "version": "0.1",
  "kind": "web-library",
  "trust": "official",
  "description": "SVG icon components + devicons CSS helpers for RWE templates. 78 Lucide-style icons and ensureDevicons, dbKindIconClass, dbObjectIconClass.",
  "source": {
    "provider": "zebflow",
    "package": "icons",
    "package_version": "bridge",
    "packed_version": "full-0.1",
    "packed_kind": "full",
    "entry": "runtime/icons.bundle.mjs"
  },
  "registry": {
    "kind": "github-releases",
    "repo": "zebflow/libraries",
    "asset_pattern": "zeb-icons-{version}.bundle.mjs"
  },
  "exports": {
    "raw": [
