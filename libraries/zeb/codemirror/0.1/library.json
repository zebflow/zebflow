{
  "name": "zeb/codemirror",
  "version": "0.1",
  "kind": "web-library",
  "trust": "official",
  "description": "CodeMirror 6 runtime for rich code editing experiences in TSX templates.",
  "source": {
    "provider": "esm.sh",
    "package": "codemirror",
    "package_version": "6.0.1",
    "packed_version": "full-0.1",
    "packed_kind": "full",
    "entry": "runtime/entry.mjs"
  },
  "registry": {
    "kind": "github-releases",
    "repo": "zebflow/libraries",
    "asset_pattern": "zeb-codemirror-{version}.bundle.mjs"
  },
  "exports": {
    "raw": [
      "codemirror",
      "presets",
      "createZebflowEditorExtensions"
    ],
    "wrappers": [
      "CodeEditor"
    ]
  },
  "runtime": {
    "format": "esm",
    "entry": "runtime/entry.mjs"
  },
  "editor": {
    "keywords": "keywords.json",
    "exports": "exports.json"
  }
}
